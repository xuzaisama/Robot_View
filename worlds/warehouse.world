            <diffuse>0.0 0.0 0.8 0.6</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Dynamic obstacles controlled via forklift_controller.py -->
    <model name="forklift">
      <static>false</static>
      <pose>5 3.5 0.3 0 0 1.5708</pose>
      <link name="chassis">
        <pose>0 0 0.3 0 0 0</pose>
        <visual name="visual">
          <geometry><box><size>1.5 0.7 0.6</size></box></geometry>
          <material>
            <ambient>0.9 0.7 0.1 1.0</ambient>
            <diffuse>0.9 0.7 0.1 1.0</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><box><size>1.5 0.7 0.6</size></box></geometry>
        </collision>
      </link>
      <link name="fork">
        <pose>0.9 0 0.15 0 0 0</pose>
        <visual name="visual">
          <geometry><box><size>0.3 0.6 0.3</size></box></geometry>
          <material>
            <ambient>0.3 0.3 0.3 1.0</ambient>
            <diffuse>0.4 0.4 0.4 1.0</diffuse>
          </material>
        </visual>
        <collision name="collision">
          <geometry><box><size>0.3 0.6 0.3</size></box></geometry>
        </collision>
      </link>
      <joint name="fork_joint" type="fixed">
        <parent>chassis</parent>
        <child>fork</child>
      </joint>
    </model>

