    <!-- ========== Loading/Unloading Zone Markers ========== -->
    <model name="loading_zone_a">
      <static>true</static>
      <pose>7 -2.5 0.01 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>2.0 2.0 0.02</size></box></geometry>
          <material>
            <ambient>0.0 0.8 0.0 0.6</ambient>
            <diffuse>0.0 0.8 0.0 0.6</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="loading_zone_b">
      <static>true</static>
      <pose>7 0 0.01 0 0 0</pose>
      <link name="link">
        <visual name="visual">
          <geometry><box><size>2.0 2.0 0.02</size></box></geometry>
          <material>
