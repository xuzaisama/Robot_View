Panels:
  - Class: rviz_common/Displays
    Name: Displays
  - Class: rviz_common/Views
    Name: Views
Visualization Manager:
  Class: ""
  Displays:
    - Class: rviz_default_plugins/TF
      Name: TF
      Enabled: true
      Marker Scale: 0.3
      Frame Timeout: 15
    - Class: rviz_default_plugins/Map
      Name: Global Map
      Enabled: true
      Topic:
        Depth: 1
        Reliability: 1
        Value: /map
      Color Scheme: map
      Draw Behind: false
    - Class: rviz_default_plugins/Map
      Name: Global Costmap
      Enabled: false
      Topic:
        Depth: 1
        Reliability: 1
        Value: /global_costmap/costmap
      Color Scheme: costmap
      Draw Behind: false
    - Class: rviz_default_plugins/Map
      Name: Local Costmap
      Enabled: true
      Topic:
        Depth: 1
        Reliability: 1
        Value: /local_costmap/costmap
      Color Scheme: costmap
      Draw Behind: false
    - Class: rviz_default_plugins/LaserScan
      Name: LaserScan
      Enabled: true
      Topic:
        Depth: 1
        Reliability: 1
        Value: /scan
      Style: Points
      Size (m): 0.02
    - Class: rviz_default_plugins/RobotModel
      Name: RobotModel
      Enabled: true
      Description Source: Topic
      Description Topic:
        Depth: 1
        Reliability: 1
        Value: /robot_description
    - Class: rviz_default_plugins/Path
      Name: Global Plan
      Enabled: true
      Topic:
        Depth: 1
        Reliability: 1
        Value: /plan
      Color: 0 255 0
      Alpha: 0.8
    - Class: rviz_default_plugins/Path
      Name: Local Plan
      Enabled: true
      Topic:
        Depth: 1
        Reliability: 1
        Value: /local_plan
      Color: 255 0 255
      Alpha: 0.6
    - Class: rviz_default_plugins/Path
      Name: Smac Plan
      Enabled: false
      Topic:
        Depth: 1
        Reliability: 1
        Value: /received_global_plan
    - Class: nav2_rviz_plugins/ParticleCloud
      Name: AMCL Particles
      Enabled: true
      Topic:
        Depth: 1
        Reliability: 1
        Value: /particle_cloud
      Color: 255 255 0
      Alpha: 0.5
    - Class: rviz_default_plugins/MarkerArray
      Name: Waypoint Markers
      Enabled: true
      Topic:
        Depth: 1
        Reliability: 1
        Value: /waypoints
  Global Options:
    Background Color: 30 30 30
    Fixed Frame: map
    Frame Rate: 30
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/Interact
    - Class: rviz_default_plugins/Select
    - Class: rviz_default_plugins/SetInitialPose
    - Class: rviz_default_plugins/SetGoal
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 15
      Focal Point: [0, 0, 0]
      Name: Current View
      Pitch: 0.785
      Yaw: 0.785
